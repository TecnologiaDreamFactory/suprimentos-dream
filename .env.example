# Copie para .env e preencha OPENAI_API_KEY manualmente.
# Nunca commite o arquivo .env com chaves reais.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ENABLE_AMBIGUITY_RESOLUTION=true
OPENAI_ENABLE_ANALYTIC_SUMMARY=true
OPENAI_PARSING_CONFIDENCE_THRESHOLD=0.75
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=1
OPENAI_TEMPERATURE=0.2

# Equivalência semântica de itens no batch (opcional; complementa determinístico)
OPENAI_ENABLE_SEMANTIC_ITEM_MATCH=true
OPENAI_SEMANTIC_ITEM_MATCH_THRESHOLD=0.80
OPENAI_SEMANTIC_ITEM_MATCH_LOW_CONFIDENCE=0.60
OPENAI_SEMANTIC_ITEM_MATCH_MAX_CANDIDATES=5
OPENAI_SEMANTIC_ITEM_MATCH_MAX_CALLS=10
# Opcional: timeout só desta chamada (senão usa OPENAI_TIMEOUT_MS)
# OPENAI_SEMANTIC_ITEM_MATCH_TIMEOUT_MS=15000

# PDF / DOCX / TXT → texto → extração de itens via modelo (compare-batch e /api/compare)
# OPENAI_ENABLE_DOCUMENT_INGEST=0   # opcional: desliga PDF/DOCX/TXT (com chave, ingestão documento fica ligada por padrão)
# OPENAI_DOCUMENT_INGEST_MAX_CHARS=120000
# OPENAI_DOCUMENT_INGEST_TIMEOUT_MS=60000

# Download do XLSX em lote (GET /downloads/...)
# BATCH_DOWNLOAD_REQUIRE_TOKEN=true  → exige ?token= na URL
# BATCH_DOWNLOAD_TOKEN_TTL_MS=900000  → validade do token (ms), padrão 15 min
# BATCH_DOWNLOAD_CONSUME_TOKEN_ON_SUCCESS=true  → apaga o token após 1º download (link de uso único). Padrão: desligado — permite baixar várias vezes com o mesmo link até expirar.
